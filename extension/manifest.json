{
  "manifest_version": 3,
  "name": "X & Xiaohongshu Photo Saver",
  "version": "0.2.0",
  "description": "Right-click X / Xiaohongshu images to save into macOS Photos (no watermark).",
  "permissions": [
    "contextMenus",
    "nativeMessaging",
    "notifications"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://*.twimg.com/*",
    "https://*.xiaohongshu.com/*",
    "https://*.xhscdn.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.xiaohongshu.com/*",
        "https://xiaohongshu.com/*"
      ],
      "js": ["content_xhs.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "key": ""
}